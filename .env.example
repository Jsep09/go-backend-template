# ==========================================
# App
# ==========================================
APP_ENV=development          # development | production
APP_PORT=3000
APP_NAME=go-backend-template

# ==========================================
# Supabase / Database
# ==========================================
# หา DATABASE_URL ได้จาก Supabase Dashboard > Settings > Database > Connection string
# เลือก "URI" แล้วแทน [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# สำหรับ pgBouncer (connection pooling) — แนะนำสำหรับ production
DATABASE_URL_POOLER=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ==========================================
# Supabase Auth
# ==========================================
# หาได้จาก Supabase Dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Supabase project URL และ anon key (ถ้าต้องการเรียก Supabase API โดยตรง)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# CORS
# ==========================================
# คั่นด้วย comma ถ้ามีหลาย origin
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_MAX=60          # requests
RATE_LIMIT_WINDOW=1        # minutes